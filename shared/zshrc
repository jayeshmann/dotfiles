# ============================================================
# PATH
# ============================================================
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.npm-global/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init - zsh)"
eval "$(pyenv virtualenv-init -)"
# ============================================================
# History
# ============================================================
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS APPEND_HISTORY INC_APPEND_HISTORY

# ============================================================
# Completion
# ============================================================
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"  # color completion menu
zstyle ':completion:*' rehash true                        # auto-rehash new binaries
zstyle ':completion:*' verbose yes
zstyle ':completion:*:descriptions' format '%B%d%b'
zstyle ':completion:*:warnings' format 'No matches for: %d'
# ============================================================
# Plugins
# ============================================================
source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh 2>/dev/null
source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh 2>/dev/null

# ============================================================
# fzf keybindings (Ctrl+R history, Ctrl+T file search, Alt+C cd)
# ============================================================
[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ] && source /usr/share/doc/fzf/examples/key-bindings.zsh
[ -f /usr/share/doc/fzf/examples/completion.zsh ]   && source /usr/share/doc/fzf/examples/completion.zsh

# ============================================================
# Aliases — Claude Code workflow
# ============================================================
alias lg='lazygit'
alias cc='claude'
alias ccr='claude --resume'
alias ccy='claude --dangerously-skip-permissions'  # YOLO mode — only in worktrees/containers
alias cat='bat --paging=never'
alias ll='ls -lah --color=auto'
alias la='ls -A --color=auto'
alias gs='git status -sb'
alias gd='git diff'
alias gds='git diff --staged'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline --graph --decorate -20'

# Quick cd to projects
alias proj='cd ~/code'
alias claudeignore='cp ~/.config/claude/claudeignore.template .claudeignore'

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"

# ============================================================
# Dev environments (ported from .bashrc)
# ============================================================

# Rust / Cargo
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Java
export JAVA_HOME="/usr/lib/jvm/java-17-openjdk-amd64"

# Android SDK + NDK
export ANDROID_HOME="$HOME/android-sdk"
export ANDROID_NDK_HOME="$ANDROID_HOME/ndk/29.0.13113456"

# Flutter + Android tools on PATH
export PATH="$HOME/flutter/bin:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$PATH"

alias cmem-worker='cd ~/.claude/plugins/marketplaces/thedotmack && npm run worker:status'
alias cmem-start='cd ~/.claude/plugins/marketplaces/thedotmack && npm run worker:start'
alias cmem-stop='cd ~/.claude/plugins/marketplaces/thedotmack && npm run worker:stop'
alias cmem-restart='cd ~/.claude/plugins/marketplaces/thedotmack && npm run worker:restart'

# Auto-start claude-mem worker if not running
if ! ss -tlnp 2>/dev/null | grep -q ":37777 "; then
  (cd ~/.claude/plugins/marketplaces/thedotmack && npm run worker:start &>/dev/null &) 2>/dev/null
fi

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Better defaults
alias df='df -h'
alias du='du -h'
alias mkdir='mkdir -pv'

# Reload zsh config
alias zr='exec zsh'

# Edit zshrc fast
alias zc='${EDITOR:-code} ~/.zshrc'

# Show top 10 disk hogs in current dir
alias bigdirs='du -h --max-depth=1 | sort -rh | head -11'

# IP address
alias myip='curl -s https://api.ipify.org && echo'

# ============================================================
# Starship prompt (must be last)
# ============================================================
eval "$(starship init zsh)"


