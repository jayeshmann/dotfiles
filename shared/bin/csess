#!/usr/bin/env bash
# csess — list past Claude Code sessions with their first user message.
# Usage:
#   csess              # last 20 sessions
#   csess -n 50        # last 50
#   csess -a           # all
#   csess <pattern>    # filter (substring match on cwd or first msg)
set -eu

log="$HOME/.claude/sessions.log"
[[ -f "$log" ]] || { echo "no sessions log at $log" >&2; exit 1; }

n=20
pattern=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -n) n="$2"; shift 2 ;;
    -a) n=0; shift ;;
    -h|--help) sed -n '2,7p' "$0" | sed 's/^# \?//'; exit 0 ;;
    *)  pattern="$1"; shift ;;
  esac
done

extract_first_msg() {
  local path="$1"
  [[ -f "$path" ]] || { echo ""; return; }
  { jq -r '
    select(.type == "user" and .message.role == "user")
    | (.message.content
        | if type == "string" then .
          else (.[]? | select(.type == "text") | .text // empty)
          end)
    | select(. != null and . != "")
  ' "$path" 2>/dev/null || true; } \
    | head -1 \
    | tr '\n' ' ' \
    | sed -E 's/^[[:space:]]+|[[:space:]]+$//g; s/[[:space:]]+/ /g' \
    | cut -c1-100
}

# Read log lines, optionally tail to last N
if [[ "$n" -gt 0 ]]; then
  lines=$(tail -n "$n" "$log")
else
  lines=$(cat "$log")
fi

while IFS= read -r line; do
  [[ -z "$line" ]] && continue
  ts=$(jq -r '.ts'              <<<"$line")
  sid=$(jq -r '.sid'             <<<"$line")
  cwd=$(jq -r '.cwd'             <<<"$line")
  src=$(jq -r '.source // "?"'   <<<"$line")
  tp=$(jq -r '.transcript_path'  <<<"$line")
  when=$(date -d "@$ts" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "$ts")
  first_msg=$(extract_first_msg "$tp")
  out=$(printf '%s  %-8s  %-7s  %s\n    %s\n' \
        "$when" "${sid:0:8}" "$src" "$cwd" "${first_msg:-(no user msg yet)}")
  if [[ -n "$pattern" ]]; then
    grep -qiE "$pattern" <<<"$out" || continue
  fi
  printf '%s\n' "$out"
done <<<"$lines"
