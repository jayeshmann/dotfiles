#!/usr/bin/env bash
# Single entry point for managing dotfiles across WSL and macOS.
#
# Usage:
#   ./dot              # interactive menu
#   ./dot bootstrap    # apply repo → live (one-time setup; clones+builds deps)
#   ./dot sync         # capture live → repo (run before commit)
#   ./dot restore      # roll back to the most recent .bak.<ts> backup
#   ./dot help
#
# Direction model:
#   bootstrap : repo → live   (writes ~/.zshrc, ~/.claude/*, etc.)
#   sync      : live → repo   (pulls your edits back into shared/...)
#   restore   : .bak.<ts> → live (undoes the most recent bootstrap)
#
# OS detection:
#   $OSTYPE captures the platform once. bootstrap branches on it for things
#   like RTK install (brew vs install.sh), the skills layout (mac uses
#   ~/.agents/skills + symlinks; wsl writes directly), and which extra
#   files to ship (wezterm.lua + PowerShell notify-attention.sh on WSL only).
set -euo pipefail
cd "$(dirname "$0")"

# ─── OS detection ─────────────────────────────────────────────────────────────
case "$OSTYPE" in
  darwin*) OS=mac   ;;
  linux*)  OS=linux ;;
  *)       OS=other ;;
esac

ts=$(date +%s)
backup() { [[ -e "$1" ]] && cp "$1" "$1.bak.$ts" || true; }
copy_subst()   { sed "s|__HOME__|${HOME}|g" "$1" > "$2"; }
copy_unsubst() { sed "s|${HOME}|__HOME__|g" "$1" > "$2"; }
# Strip codex's [projects.*] trust blocks during live→repo sync. Trust paths
# are per-machine state (codex appends them when you trust a project) and use
# absolute paths that differ across OSes — they don't belong in the repo.
# Cross-OS settings (model, [tui], etc.) flow through unchanged.
copy_codex_filter() {
  awk '
    /^\[projects\./ { skip=1; next }
    /^\[/           { skip=0 }
    !skip
  ' "$1" > "$2"
}
link_skill()   { local src="$1" name="$2"; rm -rf "${HOME}/.claude/skills/${name}"; ln -s "$src" "${HOME}/.claude/skills/${name}"; }

# ─── Tracked file pairs (live ↔ repo) ─────────────────────────────────────────
# Each entry: "live_path repo_path subst_mode". subst_mode:
#   plain        — straight cp in both directions
#   subst        — __HOME__↔$HOME substitution
#   codex_filter — sync (live→repo) strips [projects.*] trust blocks;
#                  bootstrap (repo→live) is plain copy

SYNC_PAIRS=(
  "$HOME/.zshrc.common                          shared/zshrc.common                           plain"
  "$HOME/.claude/settings.json                  shared/claude/settings.json                   plain"
  "$HOME/.claude/CLAUDE.md                      shared/claude/CLAUDE.md                       plain"
  "$HOME/.claude/RTK.md                         shared/claude/RTK.md                          plain"
  "$HOME/.claude/codex-review.schema.json       shared/claude/codex-review.schema.json        plain"
  "$HOME/.claude/codex-options-review.schema.json shared/claude/codex-options-review.schema.json plain"
  "$HOME/.claude/bin/codex-precommit.sh         shared/claude/bin/codex-precommit.sh          plain"
  "$HOME/.claude/bin/codex-second-opinion.sh    shared/claude/bin/codex-second-opinion.sh     plain"
  "$HOME/.claude/bin/ctx-pct-colored.sh         shared/claude/bin/ctx-pct-colored.sh          plain"
  "$HOME/.claude/bin/log-session.sh             shared/claude/bin/log-session.sh              plain"
  "$HOME/.claude/bin/options-review-gate.sh     shared/claude/bin/options-review-gate.sh      plain"
  "$HOME/.claude/bin/pre-commit-review-gate.sh  shared/claude/bin/pre-commit-review-gate.sh   plain"
  "$HOME/.claude/bin/upgrade-ccstatusline.sh    shared/claude/bin/upgrade-ccstatusline.sh     plain"
  "$HOME/.claude/bin/upgrade-skills.sh          shared/claude/bin/upgrade-skills.sh           plain"
  "$HOME/.config/starship.toml                  shared/starship/starship.toml                 plain"
  "$HOME/.codex/config.toml                     shared/codex/config.toml                      codex_filter"
  "$HOME/.codex/AGENTS.md                       shared/codex/AGENTS.md                        plain"
  "$HOME/.codex/RTK.md                          shared/codex/RTK.md                           plain"
  "$HOME/.config/ccstatusline/settings.json     shared/ccstatusline/settings.json             subst"
)
# Linux-only extras
LINUX_EXTRA_PAIRS=(
  "$HOME/.hermes/config.yaml                    shared/hermes/config.yaml                     plain"
  "$HOME/.claude/bin/notify-attention.sh        wsl/claude-bin/notify-attention.sh            plain"
  "/mnt/c/Users/jay/.wezterm.lua                wsl/wezterm.lua                               plain"
)

active_pairs() {
  for p in "${SYNC_PAIRS[@]}"; do echo "$p"; done
  if [[ "$OS" == "linux" ]]; then
    for p in "${LINUX_EXTRA_PAIRS[@]}"; do echo "$p"; done
  fi
}

# ─── BOOTSTRAP ────────────────────────────────────────────────────────────────
install_prereqs() {
  # Install everything `./dot bootstrap` and shared/zshrc.common need at runtime.
  # Idempotent: skips packages already on PATH so re-runs are cheap.
  #
  # Mac: everything via brew (including bun via the oven-sh tap). Linux:
  # jq/fzf/git/curl via apt; starship and bun via their official curl-pipe-sh
  # installers because neither ships in stock Ubuntu repos.
  # zsh-autosuggestions / zsh-syntax-highlighting are intentionally NOT
  # installed at the system level — `shared/zshrc.common` loads them through
  # zinit from upstream, so apt/brew copies would be dead weight.
  if [[ "$OS" == "mac" ]]; then
    if ! command -v brew >/dev/null 2>&1; then
      echo "ERR: brew not installed. Install Homebrew first: https://brew.sh" >&2
      exit 1
    fi
    local pkgs=()
    command -v jq       >/dev/null 2>&1 || pkgs+=( jq )
    command -v fzf      >/dev/null 2>&1 || pkgs+=( fzf )
    command -v starship >/dev/null 2>&1 || pkgs+=( starship )
    command -v git      >/dev/null 2>&1 || pkgs+=( git )
    command -v bun      >/dev/null 2>&1 || pkgs+=( oven-sh/bun/bun )
    if (( ${#pkgs[@]} )); then
      echo "==> brew install ${pkgs[*]}"
      brew install "${pkgs[@]}"
    fi
  elif [[ "$OS" == "linux" ]]; then
    if ! command -v apt-get >/dev/null 2>&1; then
      echo "ERR: non-apt Linux detected. Install curl, jq, fzf, starship, git, bun manually, then re-run." >&2
      exit 1
    fi
    local pkgs=()
    command -v curl >/dev/null 2>&1 || pkgs+=( curl )
    command -v jq   >/dev/null 2>&1 || pkgs+=( jq )
    command -v fzf  >/dev/null 2>&1 || pkgs+=( fzf )
    command -v git  >/dev/null 2>&1 || pkgs+=( git )
    if (( ${#pkgs[@]} )); then
      echo "==> sudo apt-get install -y ${pkgs[*]}"
      sudo apt-get update -qq
      sudo apt-get install -y "${pkgs[@]}"
    fi
    if ! command -v starship >/dev/null 2>&1; then
      echo "==> installing starship (curl | sh — official installer; uses sudo to write /usr/local/bin)"
      curl -fsSL https://starship.rs/install.sh | sh -s -- -y
    fi
    if ! command -v bun >/dev/null 2>&1; then
      echo "==> installing bun (curl | bash)"
      curl -fsSL https://bun.sh/install | bash
      export PATH="$HOME/.bun/bin:$PATH"
    fi
  else
    echo "ERR: unsupported OS ($OSTYPE). Bootstrap supports macOS and Linux." >&2
    exit 1
  fi

  # Claude Code: stays manual because first-run is an interactive auth flow.
  if ! command -v claude >/dev/null 2>&1; then
    echo "ERR: claude not installed. Follow https://docs.claude.com/en/docs/claude-code/setup, then re-run." >&2
    exit 1
  fi
}

cmd_bootstrap() {
  echo "==> bootstrap on $OS (ts=$ts)"

  # Pull latest from origin before applying so bootstrap writes the newest
  # tracked content. --ff-only refuses to merge if local has diverged — in
  # that case bootstrap stops and the user reconciles manually.
  if git rev-parse --git-dir >/dev/null 2>&1 && git remote get-url origin >/dev/null 2>&1; then
    echo "==> updating dotfiles from origin (git pull --ff-only)"
    git fetch -q origin
    git pull --ff-only
  fi

  install_prereqs

  mkdir -p ~/.claude/bin ~/.config/ccstatusline ~/.codex \
           ~/.local/share ~/.local/state/dotfiles \
           ~/.claude/skills ~/.agents/skills

  # zinit (both OSes — shared/zshrc.common requires it for turbo loading)
  ZINIT_HOME="$HOME/.local/share/zinit/zinit.git"
  if [[ ! -d "$ZINIT_HOME/.git" ]]; then
    echo "==> installing zinit"
    git clone --depth=1 https://github.com/zdharma-continuum/zinit "$ZINIT_HOME"
  fi

  # codex CLI (Mac auto-install via brew; on Linux, expect manual install)
  if [[ "$OS" == "mac" ]] && ! command -v codex >/dev/null 2>&1; then
    echo "==> brew install codex"
    brew install codex
  fi

  # RTK (Mac via brew; Linux via curl-pipe-sh)
  if ! command -v rtk >/dev/null 2>&1; then
    echo "==> installing RTK"
    if [[ "$OS" == "mac" ]]; then
      brew install rtk 2>/dev/null || curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh
    else
      curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh
    fi
  fi

  # ccstatusline (build main HEAD)
  ccs="$HOME/.local/share/ccstatusline"
  if [[ ! -d "$ccs/.git" ]]; then
    git clone https://github.com/sirmalloc/ccstatusline "$ccs"
  else
    git -C "$ccs" pull --ff-only
  fi
  (cd "$ccs" && bun install && bun run build)
  [[ -f "$ccs/dist/ccstatusline.js" ]] || { echo "ERR: ccstatusline build failed" >&2; exit 1; }

  # Replace tracked live files
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    src=$(echo "$line" | awk '{print $2}')   # repo path
    dst=$(echo "$line" | awk '{print $1}')   # live path
    mode=$(echo "$line" | awk '{print $3}')
    [[ -e "$src" ]] || continue
    mkdir -p "$(dirname "$dst")"
    backup "$dst"
    if [[ "$mode" == "subst" ]]; then
      copy_subst "$src" "$dst"
    else
      cp "$src" "$dst"
    fi
  done < <(active_pairs)

  chmod +x ~/.claude/bin/*.sh 2>/dev/null || true

  # Idempotently inject the source-stub into ~/.zshrc. ~/.zshrc itself is
  # owned by the user / installers (brew, nvm, pyenv, etc. all `>>` to it);
  # we only ever APPEND a marker-guarded one-liner so the common file gets
  # picked up after their main body.
  STUB_MARKER='# >>> dotfiles common <<<'
  STUB_BODY='[ -f "$HOME/.zshrc.common" ] && . "$HOME/.zshrc.common"'
  if [[ -f "$HOME/.zshrc" ]] && grep -qF "$STUB_MARKER" "$HOME/.zshrc"; then
    : # already injected — leave it
  else
    {
      printf '\n%s\n' "$STUB_MARKER"
      printf '%s\n' "$STUB_BODY"
    } >> "$HOME/.zshrc"
    echo "==> appended dotfiles-common stub to ~/.zshrc (your existing config is untouched)"
  fi

  # Skills
  if [[ "$OS" == "mac" ]]; then
    # Mac: ~/.agents/skills/<name> + symlinks into ~/.claude/skills/<name>
    mp_tmp=$(mktemp -d)
    if git clone --depth 1 https://github.com/mattpocock/skills "$mp_tmp"; then
      for category in engineering productivity misc; do
        for d in "$mp_tmp/skills/$category"/*/; do
          [[ -d "$d" ]] || continue
          name=$(basename "$d")
          rm -rf "$HOME/.agents/skills/$name"
          cp -r "$d" "$HOME/.agents/skills/$name"
          link_skill "$HOME/.agents/skills/$name" "$name"
        done
      done
    else
      echo "WARN: mattpocock/skills clone failed — skills not refreshed." >&2
    fi
    rm -rf "$mp_tmp"

    if [[ -d shared/claude/skills ]]; then
      for d in shared/claude/skills/*/; do
        [[ -d "$d" ]] || continue
        name=$(basename "$d")
        rm -rf "$HOME/.agents/skills/$name"
        cp -r "$d" "$HOME/.agents/skills/$name"
        link_skill "$HOME/.agents/skills/$name" "$name"
      done
    fi
  else
    # WSL: direct copy into ~/.claude/skills/<name>
    mp_tmp=$(mktemp -d)
    if git clone --depth 1 https://github.com/mattpocock/skills "$mp_tmp"; then
      for category in engineering productivity misc; do
        for d in "$mp_tmp/skills/$category"/*/; do
          [[ -d "$d" ]] || continue
          name=$(basename "$d")
          rm -rf "$HOME/.claude/skills/$name"
          cp -r "$d" "$HOME/.claude/skills/$name"
        done
      done
    else
      echo "WARN: mattpocock/skills clone failed." >&2
    fi
    rm -rf "$mp_tmp"

    if [[ -d shared/claude/skills ]]; then
      for d in shared/claude/skills/*/; do
        [[ -d "$d" ]] || continue
        name=$(basename "$d")
        rm -rf "$HOME/.claude/skills/$name"
        cp -r "$d" "$HOME/.claude/skills/$name"
      done
    fi
  fi

  echo
  echo "bootstrap complete (backup ts=$ts). Roll back with: ./dot restore"
}

# ─── SYNC ─────────────────────────────────────────────────────────────────────
cmd_sync() {
  echo "==> sync on $OS"
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    src=$(echo "$line" | awk '{print $1}')   # live path
    dst=$(echo "$line" | awk '{print $2}')   # repo path
    mode=$(echo "$line" | awk '{print $3}')
    [[ -e "$src" ]] || continue
    mkdir -p "$(dirname "$dst")"
    case "$mode" in
      subst)        copy_unsubst       "$src" "$dst" ;;
      codex_filter) copy_codex_filter  "$src" "$dst" ;;
      *)            cp                 "$src" "$dst" ;;
    esac
  done < <(active_pairs)

  echo "synced. git status:"
  git status -sb
}

# ─── RESTORE ──────────────────────────────────────────────────────────────────
cmd_restore() {
  echo "==> restore on $OS"
  targets=()
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    targets+=( "$(echo "$line" | awk '{print $1}')" )
  done < <(active_pairs)

  plan=()
  found_any=false
  for t in "${targets[@]}"; do
    latest=$(ls -1t "${t}".bak.* 2>/dev/null | head -1 || true)
    if [[ -n "$latest" ]]; then
      plan+=( "$t  ←  $latest" )
      found_any=true
    fi
  done

  if ! $found_any; then
    echo "no .bak.<ts> files found for any tracked target. Nothing to restore." >&2
    exit 1
  fi

  echo "Restore plan:"
  for line in "${plan[@]}"; do echo "  $line"; done
  echo
  printf 'Proceed? [y/N] '
  read -r ans
  case "$ans" in
    y|Y|yes|YES) ;;
    *) echo "aborted."; exit 0 ;;
  esac

  for t in "${targets[@]}"; do
    latest=$(ls -1t "${t}".bak.* 2>/dev/null | head -1 || true)
    [[ -n "$latest" ]] || continue
    cp "$latest" "$t"
    echo "restored: $t"
  done
  echo "restore done."
}

# ─── HELP / MENU ──────────────────────────────────────────────────────────────
cmd_help() {
  cat <<EOF
./dot — manage dotfiles across WSL and macOS.

Subcommands:
  bootstrap   apply repo → live (one-time setup; clones+builds deps)
  sync        capture live → repo (run before commit)
  restore     roll back to the most recent .bak.<ts> backup
  help        this message

OS detected: $OS

bootstrap installs (when missing):
  - Mac (brew): jq, fzf, starship, git, bun (oven-sh tap), codex
  - Linux (apt): curl, jq, fzf, git
  - Linux (curl|sh): starship, bun (not in stock Ubuntu repos)
  - Cross-OS from source/git: zinit, RTK, ccstatusline
Only \`claude\` itself stays manual — the first-run auth is interactive.

Backups: every replaced live file is preserved at <path>.bak.<ts>. Use
\`./dot restore\` to roll back to the latest batch.
EOF
}

cmd_menu() {
  while true; do
    echo
    echo "./dot — dotfiles manager (OS: $OS)"
    echo "  1) bootstrap   (repo → live)"
    echo "  2) sync        (live → repo)"
    echo "  3) restore     (.bak.<ts> → live)"
    echo "  4) help"
    echo "  q) quit"
    printf 'choose [1-4,q]: '
    read -r choice
    case "$choice" in
      1) cmd_bootstrap ;;
      2) cmd_sync ;;
      3) cmd_restore ;;
      4) cmd_help ;;
      q|Q|"") echo "bye."; exit 0 ;;
      *) echo "unknown choice: $choice" ;;
    esac
  done
}

# ─── Dispatch ─────────────────────────────────────────────────────────────────
case "${1:-}" in
  bootstrap) cmd_bootstrap ;;
  sync)      cmd_sync ;;
  restore)   cmd_restore ;;
  help|-h|--help) cmd_help ;;
  "")        cmd_menu ;;
  *) echo "unknown subcommand: $1"; cmd_help; exit 1 ;;
esac
